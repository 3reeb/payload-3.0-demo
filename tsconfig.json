{
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "target": "esnext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowJs": true,
    "checkJs": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "preserve",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "noEmit": false,
    "outDir": "./dist",
    "resolveJsonModule": true,
    "rootDir": ".",
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": false,
    "baseUrl": ".",
    "types": [
      "jest",
      "node",
      "@types/jest"
    ],
    "incremental": true,
    "isolatedModules": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@payload-config": ["./payload.config.ts"],
      "@/payload-types": [
        "./payload-types"
      ],
      "@3reen/state-letters-monitoring": [
        "./packages/state-letters-monitoring/src"
      ],
      "react": [
        "./node_modules/@types/react"
      ],
    //   "@3reeb/ui": ["./packages/3reeb-ui/dist"] ,
    // "@3reeb/utilities": ["./packages/utilities/dist"] ,
    // "@3reeb/fields": ["./packages/3reeb-fields/dist"],
    // "@3reeb/blocks": ["./packages/3reeb-blocks/dist"]
      
      
      
    },
    "composite": true
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": [
    "dist",
    "build",
    "temp",
    "node_modules",
    "models",
    "packages"
  ]
  // ,
  // "references": [
  //   { "path": "./packages/3reeb-ui" },
  //   { "path": "./packages/3reeb-fields" },
  //   { "path": "./packages/3reeb-blocks" },
  //   {"path": "./packages/state-letters-monitoring"}
  //   // Add references to all your packages here
  // ]
}
